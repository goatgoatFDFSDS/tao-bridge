# ── Deployer wallet (used by Hardhat deploy scripts)
DEPLOYER_PRIVATE_KEY=0x...

# ── Relayer wallet (used by the relayer process)
# This wallet needs:
#   - TAO on Bittensor EVM (to send to users bridging in)
#   - ETH on Ethereum (gas for release txs)
#   - ETH on Base    (gas for release txs)
#   - BNB on BSC     (gas for release txs)
RELAYER_PRIVATE_KEY=0x...
RELAYER_ADDRESS=0x...

# ── RPC endpoints (use private RPCs like Alchemy/Infura in production)
ETH_RPC=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
BSC_RPC=https://bsc-dataseed.binance.org
BITTENSOR_RPC=https://lite.chain.opentensor.ai

# ── Vault addresses on source chains (filled after deploy/01_deploy_vaults.js)
ETH_VAULT_ADDRESS=
BASE_VAULT_ADDRESS=
BSC_VAULT_ADDRESS=

# ── TaoReceiver on Bittensor EVM (filled after deploy/02_deploy_tao_receiver.js)
BITTENSOR_TAO_RECEIVER_ADDRESS=
